# Postgres connection string
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Allowed CORS origin for the client (defaults to http://localhost:3000)
CLIENT_ORIGIN=http://localhost:3000

# Server port (defaults to 4000)
PORT=4000

# Google Cloud Storage
GCS_BUCKET_NAME=
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_EMAIL=
GCP_CLIENT_ID=
GCP_PRIVATE_KEY_ID=
# Paste the full private_key from the service account JSON. Keep \n as literal
# backslash-n inside the double quotes — the app converts them back to newlines.
GCP_PRIVATE_KEY=""
