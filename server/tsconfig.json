{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES2023",
    "strict": true,
    "paths": {
      "@newformdemo/trpc": ["../packages/trpc"]
    },
    "rootDirs": [".", "../packages/trpc"],
    "declaration": true,
    "composite": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "index.ts",
    "../packages/trpc/index.ts",
    "./routes",
    "./uploads",
    "./lib/",
    "./generated/prisma/client.ts"
  ]
}
